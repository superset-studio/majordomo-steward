# =============================================================================
# Server
# =============================================================================
PORT=7680
# HOST=0.0.0.0
# READ_TIMEOUT=30s
# WRITE_TIMEOUT=600s
# UPSTREAM_TIMEOUT=600s

# =============================================================================
# Database
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=majordomo
POSTGRES_PASSWORD=
POSTGRES_DB=majordomo_steward
# POSTGRES_SSLMODE=disable
# POSTGRES_MAX_CONNS=20

# =============================================================================
# Security
# =============================================================================
# AES-256 key for encrypting proxy provider keys, hex-encoded (64 hex chars).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Token required to access the steward admin API (/admin/orgs/*).
# When set, enables: majordomo steward orgs / register / deregister
# Generate with: openssl rand -hex 32
# STEWARD_ADMIN_TOKEN=

# =============================================================================
# Butler worker intervals (shared across all registered orgs)
# Register orgs with: majordomo steward register --token <mdm_st_...> --butler-url <url>
# =============================================================================
# BATCH_INTERVAL=60s
# BATCH_MAX_SIZE=500
# KEY_SYNC_INTERVAL=5m
# JOB_POLL_INTERVAL=30s
# JOB_POLL_LIMIT=10

# =============================================================================
# Managed steward (only needed when running as a Majordomo-hosted steward)
# =============================================================================
# MANAGED_ENABLED=false
# MANAGED_MASTER_TOKEN=mdm_st_...
# MANAGED_BUTLER_URL=https://butler.majordomo.app
# MANAGED_POLL_INTERVAL=30s

# =============================================================================
# Logging
# =============================================================================
# LOG_LEVEL=info
# LOG_STORE_REQUEST_BODY=false
# LOG_STORE_RESPONSE_BODY=false
# LOG_MAX_REQUEST_BODY_SIZE=65536
# LOG_MAX_RESPONSE_BODY_SIZE=65536
# LOG_BODY_STORAGE=none   # none | postgres

# =============================================================================
# Provider base URLs (override to route through a local proxy or mock)
# =============================================================================
# OPENAI_BASE_URL=https://api.openai.com
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com
